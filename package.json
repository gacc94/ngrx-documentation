{
    "name": "ngrx-documentation",
    "version": "1.4.0",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "test": "ng test",
        "format": "biome check --write .",
        "format:check": "biome check .",
        "lint": "biome lint .",
        "ci": "biome ci .",
        "prepare": "lefthook install",
        "serve:ssr:ngrx-documentation": "node dist/ngrx-documentation/server/server.mjs"
    },
    "private": true,
    "packageManager": "bun@1.3.13",
    "dependencies": {
        "@angular-architects/ngrx-toolkit": "^21.0.1",
        "@angular/animations": "^21.2.13",
        "@angular/cdk": "^21.2.11",
        "@angular/common": "^21.2.0",
        "@angular/compiler": "^21.2.0",
        "@angular/core": "^21.2.0",
        "@angular/forms": "^21.2.0",
        "@angular/material": "^21.2.11",
        "@angular/platform-browser": "^21.2.0",
        "@angular/platform-server": "^21.2.0",
        "@angular/router": "^21.2.0",
        "@angular/ssr": "^21.2.11",
        "@ngrx/operators": "^21.1.0",
        "@ngrx/signals": "^21.1.0",
        "express": "^5.1.0",
        "rxjs": "~7.8.0",
        "tslib": "^2.3.0"
    },
    "devDependencies": {
        "@angular/build": "^21.2.10",
        "@angular/cli": "^21.2.10",
        "@angular/compiler-cli": "^21.2.0",
        "@biomejs/biome": "2.4.15",
        "@commitlint/cli": "21.0.1",
        "@commitlint/config-conventional": "21.0.1",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@types/express": "^5.0.1",
        "@types/node": "^20.17.19",
        "jsdom": "^28.0.0",
        "lefthook": "2.1.6",
        "typescript": "~5.9.2",
        "vitest": "^4.0.8"
    }
